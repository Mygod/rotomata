---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rotomata"
  description="Rotomata hosts Pokemon GO gameplay tools focused on tryhard optimization workflows."
>
  <section class="hero">
    <p class="eyebrow">Rotomata</p>
    <h1>Pokemon GO tools for people who optimize everything.</h1>
    <p class="lede">
      Rotomata is a long-lived home for practical gameplay calculators, ranking tools, and
      spreadsheet-adjacent helpers that deserve a real URL instead of another forgotten CodePen.
    </p>
  </section>

  <section class="card-grid" aria-label="Available tools">
    <article class="tool-card">
      <h2><a href="/judge">Can My Pokemon Be the Very Best Like No One Ever Was?</a></h2>
      <p>
        Multi-target filtering for “is this worth keeping?” checks across CP caps, level caps,
        purification, and strict Pareto-front Rank+ logic.
      </p>
    </article>
    <article class="tool-card">
      <h2><a href="/pvpstat">Is My Pokemon the Very Best Like No One Ever Was?</a></h2>
      <p>
        Detailed Rank+ breakdowns for one stat line, including attack, defense, HP, stat product,
        and strict-dominance reporting.
      </p>
    </article>
    <article class="tool-card">
      <h2><a href="/spinap">When to use (Silver) Pinap in raids</a></h2>
      <p>
        Ball-by-ball berry recommendations for raid catches, including Silver Pinap, Beast Ball,
        XL-candy, mega, medal, and trade-distance assumptions.
      </p>
    </article>
    <article class="tool-card">
      <h2><a href="/hardraid">Hardest Raid Bosses</a></h2>
      <p>
        Bulk-ranked raid boss table with the same tier rules, temporary evolutions, and
        double-weakness adjustments as the original calculator.
      </p>
    </article>
    <article class="tool-card">
      <h2><a href="/pvpbp">Pee vee Pee Bee Pee Filter</a></h2>
      <p>
        Table-based PvP IV filtering with Rank+, NSPP (Normalized Stat Product Percentage), stat
        floors, minimum-IV constraints, and direct links into the detailed stat breakdown tool.
      </p>
    </article>
  </section>
</BaseLayout>
