---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rotomata"
  description="Rotomata hosts Pokemon GO gameplay tools focused on tryhard optimization workflows."
>
  <section class="hero">
    <p class="eyebrow">Rotomata</p>
    <h1>Pokemon GO tools for people who optimize everything.</h1>
    <p class="lede">
      Rotomata is a long-lived home for practical gameplay calculators, ranking tools, and
      spreadsheet-adjacent helpers.
    </p>
  </section>

  <div class="tool-sections" aria-label="Available tools">
    <section class="tool-section" aria-labelledby="pvp-tools">
      <div class="tool-section-header">
        <h2 id="pvp-tools">PvP</h2>
      </div>
      <div class="card-grid">
        <article class="tool-card">
          <h2><a href="/judge">Can My Pokemon Be the Very Best Like No One Ever Was?</a></h2>
          <p>
            Multi-target filtering for “is this worth keeping?” checks across CP caps, level caps,
            purification, and strict Pareto-front Rank+ logic.
          </p>
        </article>
        <article class="tool-card">
          <h2><a href="/pvpstat">Is My Pokemon the Very Best Like No One Ever Was?</a></h2>
          <p>
            Detailed Rank+ breakdowns for one stat line, including attack, defense, HP, stat
            product, and strict-dominance reporting.
          </p>
        </article>
        <article class="tool-card">
          <h2><a href="/pvpbp">Pee vee Pee Bee Pee Filter</a></h2>
          <p>
            Table-based PvP IV filtering with Rank+, NSPP (Normalized Stat Product Percentage),
            stat floors, minimum-IV constraints, and direct links into the detailed stat breakdown
            tool.
          </p>
        </article>
        <article class="tool-card">
          <h2><a href="/pvpdps">PvP/Rocket DPS</a></h2>
          <p>
            DPS and TDO rankings for PvP and Rocket attackers, with CP-cap filtering, defender
            type matchups, Shadow variants, and the original quick-vs-charged branch behavior.
          </p>
        </article>
      </div>
    </section>

    <section class="tool-section" aria-labelledby="raid-tools">
      <div class="tool-section-header">
        <h2 id="raid-tools">Raid</h2>
      </div>
      <div class="card-grid">
        <article class="tool-card">
          <h2><a href="/spinap">When to use (Silver) Pinap in raids</a></h2>
          <p>
            Ball-by-ball berry recommendations for raid catches, including Silver Pinap, Beast
            Ball, XL-candy, mega, medal, and trade-distance assumptions.
          </p>
        </article>
        <article class="tool-card">
          <h2><a href="/hardraid">Hardest Raid Bosses</a></h2>
          <p>
            Bulk-ranked raid boss table with the same tier rules, temporary evolutions, and
            double-weakness adjustments as the original calculator.
          </p>
        </article>
      </div>
    </section>

    <section class="tool-section" aria-labelledby="max-battle-tools">
      <div class="tool-section-header">
        <h2 id="max-battle-tools">Max Battles</h2>
      </div>
      <div class="card-grid">
        <article class="tool-card">
          <h2><a href="/maxdps">Max Battle DPS</a></h2>
          <p>
            Max Move attacker rankings with Gmax coverage, Behemoth Blade adventure-effect
            variants, Eternatus handling, and optional type filtering.
          </p>
        </article>
        <article class="tool-card">
          <h2><a href="/maxbulk">Max Battle Bulk</a></h2>
          <p>
            Bulk-ranked Max Battle table with Dynamax Cannon shield assumptions, attack-type
            matchup context, and Crowned variants.
          </p>
        </article>
      </div>
    </section>

    <section class="tool-section" aria-labelledby="other-tools">
      <div class="tool-section-header">
        <h2 id="other-tools">Others</h2>
      </div>
      <div class="card-grid">
        <article class="tool-card">
          <h2>
            <a
              href="https://tiermaker.com/list/pokemon/pokemon-mega-evolutions-18840649/5864714"
              target="_blank"
              rel="noreferrer"
            >
              Mega tier list
            </a>
          </h2>
          <p>
            External reference tier list for Mega Evolutions hosted on TierMaker.
          </p>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>
