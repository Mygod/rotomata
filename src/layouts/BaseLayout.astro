---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og/rotomata-banner.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Rotomata" />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta property="og:image:width" content="2752" />
    <meta property="og:image:height" content="1536" />
    <meta property="og:image:alt" content="Rotomata banner" />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="site-brand" href="/">
          <img class="site-brand-mark" src="/logo-mark.png" alt="" />
          <span>
            <strong>Rotomata</strong>
            <small>Pokemon GO tryhard optimizations</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/">Home</a>
          <details class="site-nav-dropdown">
            <summary>PvP</summary>
            <div class="site-nav-menu">
              <a href="/judge">Can My Pokemon Be the Very Best Like No One Ever Was?</a>
              <a href="/pvpstat">Is My Pokemon the Very Best Like No One Ever Was?</a>
              <a href="/pvpbp">Pee vee Pee Bee Pee Filter</a>
              <a href="/pvpdps">PvP/Rocket DPS</a>
            </div>
          </details>
          <details class="site-nav-dropdown">
            <summary>Raid</summary>
            <div class="site-nav-menu">
              <a href="/spinap">When to use (Silver) Pinap in raids</a>
              <a href="/hardraid">Hardest Raid Bosses</a>
            </div>
          </details>
          <details class="site-nav-dropdown">
            <summary>Max Battles</summary>
            <div class="site-nav-menu">
              <a href="/maxdps">Max Battle DPS</a>
              <a href="/maxbulk">Max Battle Bulk</a>
            </div>
          </details>
          <details class="site-nav-dropdown">
            <summary>Others</summary>
            <div class="site-nav-menu">
              <a
                href="https://tiermaker.com/list/pokemon/pokemon-mega-evolutions-18840649/5864714"
                target="_blank"
                rel="noreferrer"
              >
                Mega tier list
              </a>
            </div>
          </details>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p class="legal-disclaimer">
          Rotomata is an unofficial, fan-made companion site for Pokemon GO and is
          not affiliated with or endorsed by Niantic, The Pokemon Company,
          Nintendo, Creatures Inc., or GAME FREAK. Pokemon, Pokemon GO, Pokemon
          character names, and related game content are trademarks or copyrighted
          property of their respective owners. Rotomata uses Pokemon names, stats,
          and gameplay references for informational and compatibility purposes and
          claims ownership only over its original code, calculations, writing, and
          site design.
        </p>
      </footer>
    </div>
  </body>
</html>
